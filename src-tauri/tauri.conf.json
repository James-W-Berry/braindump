{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BRAINDUMP",
  "version": "1.2.0",
  "identifier": "io.github.jameswberry.braindump",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BRAINDUMP",
        "width": 1100,
        "height": 780,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 26 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/James-W-Berry/braindump/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0RkY3QTUzQkNBMzUwMkUKUldRdVVLTzhVM3IvRkwySDFJTjZhdHVmKzZhWENDVktUektDTjF0b2V6MjZ5TW5wZk03dWw4OUQK"
    }
  }
}
